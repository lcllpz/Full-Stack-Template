{
  "name": "Full-Stack-Template-monorepo",
  "version": "0.0.1",
  "description": "Monorepo：Next.js 前端 + NestJS 后端，pnpm + Turborepo",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "keywords": [
    "next.js",
    "nestjs",
    "pnpm",
    "turborepo"
  ],
  "author": "2251086272@qq.com",
  "license": "ISC",
  "scripts": {
    "prepare": "husky",
    "dev": "turbo dev",
    "web:dev": "turbo dev --filter=@full-stack-template-monorepo/front",
    "api:dev": "turbo dev --filter=@full-stack-template-monorepo/back",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "commit": "cz"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "lint-staged": {
    "apps/front/**/*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/back/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "commitizen": "^4.3.1",
    "cz-git": "^1.13.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript-eslint": "^8.60.1"
  }
}
