# 复制为 .env 后填入本地开发值（.env 已在 .gitignore，勿提交）
# 生产环境：在部署平台注入同名环境变量，或使用 .env.production（勿提交）

PORT=4000
NODE_ENV=development

DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=root
DATABASE_NAME=fullstacktemplate

JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Redis（权限/菜单缓存，多实例部署时启用）
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0
# 可选：权限缓存 TTL（秒），未设置则与 JWT_EXPIRES_IN 一致
# REDIS_PERMISSION_CACHE_TTL_SECONDS=900