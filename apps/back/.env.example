# 复制为 .env 后填入本地开发值（.env 已在 .gitignore，勿提交）
# 生产环境：在部署平台注入同名环境变量，或使用 .env.production（勿提交）

PORT=4000
NODE_ENV=development

DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=root
DATABASE_NAME=fullstacktemplate

JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Redis（权限/菜单缓存，多实例部署时启用）
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
REDIS_DB=0
# 可选：权限缓存 TTL（秒），未设置则与 JWT_EXPIRES_IN 一致
# REDIS_PERMISSION_CACHE_TTL_SECONDS=900

# Swagger（development 默认开启，production 默认关闭）
# SWAGGER_ENABLED=true
# SWAGGER_PATH=api/docs

# 日志（Winston）
# 级别：error/warn/info/http/verbose/debug/silly（dev 默认 debug，prod 默认 info）
# LOG_LEVEL=debug
# 是否写入文件（dev 默认 false，prod 默认 true）
# 远程采集（deploy/observability Promtail→Loki）依赖文件日志，需设为 true
# LOG_FILE_ENABLED=false
# 日志目录
# LOG_DIR=logs
# 单文件最大大小，超过后切割（支持 k/m/g）
# LOG_MAX_SIZE=20m
# 日志保留：14d（按天）或纯数字（按文件个数）
# LOG_MAX_FILES=14d
# 切割后是否 gzip 压缩归档
# LOG_ZIPPED_ARCHIVE=true
# 是否记录 HTTP 访问日志
# LOG_HTTP_ENABLED=true
# 慢请求阈值（毫秒），超过以 warn 记录
# LOG_SLOW_MS=1000

# 文件存储：当前使用本地磁盘
STORAGE_DRIVER=local
# 相对目录基于后端进程的工作目录
UPLOAD_DIR=uploads
# 对外可访问的绝对地址，不要以 / 结尾
UPLOAD_PUBLIC_BASE_URL=http://localhost:4000/uploads
# 头像最大 2 MiB
UPLOAD_MAX_SIZE_BYTES=2097152
# 逗号分隔；服务端还会校验图片文件签名
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# ── 邮件（SMTP，用于发送邮箱验证码）──
# 开发环境可留空：验证码会直接打印到控制台日志；生产环境必填
MAIL_HOST=smtp.example.com
# 465=SSL 直连；587=STARTTLS（此时 MAIL_SECURE 设 false）
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=your@example.com
# QQ/163 等邮箱需填「授权码」而非登录密码
MAIL_PASSWORD=your-smtp-authcode
# 发件人地址，留空默认取 MAIL_USER
# MAIL_FROM=your@example.com
MAIL_FROM_NAME=Full-Stack-Template

# ── 短信（用于发送手机验证码）──
# 驱动：mock（默认，dev 打印到控制台）| aliyun | tencent
SMS_DRIVER=mock
# 选 aliyun/tencent 时以下必填
# SMS_ACCESS_KEY_ID=
# SMS_ACCESS_KEY_SECRET=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_CODE=

# ── 验证码（短信/邮件）──
# 验证码位数
VERIFY_CODE_LENGTH=6
# 有效期（秒）
VERIFY_CODE_TTL_SECONDS=300
# 两次发送最小间隔（秒）
VERIFY_SEND_INTERVAL_SECONDS=60
# 单个验证码最大校验错误次数，超过作废
VERIFY_MAX_ATTEMPTS=5
# 单目标单日发送上限
VERIFY_DAILY_LIMIT=10

# ── 图形验证码（SVG，发码接口前置防刷）──
# 字符数
CAPTCHA_LENGTH=4
# 有效期（秒）
CAPTCHA_TTL_SECONDS=120

# ── 队列（BullMQ，异步发送验证码，复用上方 Redis 连接参数）──
# 注意：启用验证码功能需将 REDIS_ENABLED 设为 true
QUEUE_PREFIX=fst