PORT=4000
NODE_ENV=development

DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=root
DATABASE_NAME=fullstacktemplate

JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# bcrypt 加密轮数（8~14，推荐 10；生产可调高至 12）
BCRYPT_SALT_ROUNDS=10

# Redis 配置
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=root

# 种子数据 
# 超级管理员账号（生产环境务必修改）
SUPER_ADMIN_EMAIL=super_admin_A1@qq.com
SUPER_ADMIN_PASSWORD=super_admin_A1@qq.com
# 角色名称（一般无需修改）
SUPER_ADMIN_ROLE_NAME=super_admin
# 生产环境执行种子开关（development 每次自动执行，无需此项）
RUN_SEEDS=true
# 强制重跑种子（新增菜单节点后使用）
FORCE_SEEDS=false